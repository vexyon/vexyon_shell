#!/usr/bin/env bash
# Vexyon interactive snipping tool.
#   vexyon-screenshot                -> open the Vexyon region-select overlay
#   vexyon-screenshot last           -> re-use the last crop box (no re-selecting)
#   vexyon-screenshot full           -> whole output
#   vexyon-screenshot grab "X,Y WxH" -> capture a geometry chosen by the Vexyon
#                                       themed overlay (ScreenshotOverlay.qml)
# Saves to the dir from shell.json behavior.screenshotDir (default ~/Pictures/
# Screenshots), copies to clipboard, and remembers the last region.
set -euo pipefail

CFG="$HOME/.config/vexyon/shell.json"
STATE="$HOME/.cache/vexyon/last-crop"
mkdir -p "$(dirname "$STATE")"

dir="$HOME/Pictures/Screenshots"
if command -v jq >/dev/null 2>&1 && [ -f "$CFG" ]; then
    d="$(jq -r '.behavior.screenshotDir // empty' "$CFG" 2>/dev/null || true)"
    [ -n "$d" ] && dir="${d/#\~/$HOME}"
fi
mkdir -p "$dir"
out="$dir/Screenshot_$(date +%Y-%m-%d_%H-%M-%S).png"

# Selección interactiva = el overlay QML del propio shell (temado, recuerda el
# último recorte). Al capturar, el overlay re-invoca este script con `grab`.
# Si el shell no está corriendo (TTY pelado), cae a captura de pantalla entera
# — no dependemos de slurp: el overlay ES el selector de región de Vexyon.
open_overlay() {
    if qs -p "$HOME/.config/vexyon" ipc call vexyon toggle screenshot >/dev/null 2>&1; then
        exit 0
    fi
    echo "vexyon-screenshot: shell not running; capturing the whole output" >&2
    geom=""
}

mode="${1:-region}"
geom=""
case "$mode" in
    grab)
        # Geometry picked by the themed QML overlay. It has already unmapped its
        # surface; give the compositor a frame to drop it before grim captures.
        geom="${2:-}"
        [ -z "$geom" ] && exit 0
        sleep 0.06 ;;
    last)
        [ -f "$STATE" ] && geom="$(cat "$STATE")"
        if [ -z "$geom" ]; then open_overlay; fi ;;
    full)
        geom="" ;;
    *)
        open_overlay ;;
esac

if [ -n "$geom" ]; then
    printf '%s' "$geom" > "$STATE"
    grim -g "$geom" "$out"
else
    grim "$out"
fi

# Copy to clipboard and notify.
if command -v wl-copy >/dev/null 2>&1; then
    wl-copy < "$out" --type image/png 2>/dev/null || wl-copy < "$out" 2>/dev/null || true
fi
notify-send "Vexyon" "Screenshot saved\n$out" -i "$out" 2>/dev/null || true
echo "$out"
