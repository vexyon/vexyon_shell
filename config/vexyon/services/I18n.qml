// ============================================================================
//  I18n — shell localization. ENGLISH IS THE SOURCE: every call site passes the
//  English string as the key, so `I18n.t("Settings")` returns "Settings" as-is
//  when the language is English (identity, zero-lookup) and the localized value
//  otherwise. This guarantees a fully-English UI on first boot regardless of the
//  system locale, with no risk of a missing key showing blank — an untranslated
//  key just falls back to its English self.
//
//  Language is persisted in shell.json (appearance.language) and defaults to
//  "en". Selectable in Settings. Migration is incremental: strings are wrapped
//  in I18n.t() surface by surface; anything not yet wrapped simply stays in its
//  hardcoded form until migrated. See PROJECT_STATE.md for coverage.
// ============================================================================
Singleton {
    id: root

    // Reactive: Config.appearance re-binds when shell.json changes, so a live
    // language switch re-evaluates every `text: I18n.t(...)` binding.
    readonly property string lang: (Config.appearance.language || "en")

    // Locale for date formatting (month/day names) — follows the shell
    // language, not the system locale (same pattern as the greeter snapshot).
    readonly property var locale: Qt.locale(lang === "es" ? "es_ES" : "en_US")

    readonly property var languages: [
        { code: "en", name: "English" },
        { code: "es", name: "Español" }
    ]


    function setLang(code) { Config.set("appearance", "language", code); }

    // Translate an English source string. Reads root.lang so bindings that call
    // this re-evaluate on a language change (QML tracks property reads through
    // the call). Unknown keys / English fall back to the key itself.
    function t(key) {
        if (root.lang === "en") return key;
        var d = root._dict[root.lang];
        if (d === undefined) return key;
        var v = d[key];
        return (v === undefined) ? key : v;
    }

