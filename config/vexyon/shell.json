{
  "schemaVersion": 1,
  "theme": {
    "active": "crimson-voltage"
  },
  "profile": {
    "avatar": ""
  },
  "state": {
    "firstRun": true
  },
  "appearance": {
    "cornerRadius": 12,
    "barBlur": true,
    "barBlurIntensity": 24,
    "fontFamily": "JetBrainsMono Nerd Font",
    "fontSize": 13,
    "animationSpeed": 1.0,
    "elevation": true,
    "panelBlobs": true
  },
  "bar": {
    "height": 38,
    "barSize": 38,
    "position": "top",
    "marginTop": 6,
    "marginSides": 8,
    "edgeGap": 6,
    "padding": 8,
    "screens": [],
    "autoHide": false,
    "exclusiveZone": true,
    "widgetTransparency": 1.0,
    "fontScale": 1.0,
    "iconScale": 1.0,
    "cornerRadius": 12,
    "backgroundStyle": "solid",
    "maximizeDetect": false,
    "trayTint": "none",
    "border": false,
    "widgetOutline": false,
    "shadow": "none",
    "scrollWheel": true,
    "scrollAxis": "workspace",
    "widgets": {
      "left": [
        {
          "type": "applauncher",
          "id": "applauncher-a"
        },
        {
          "type": "workspaces",
          "id": "workspaces-a"
        },
        {
          "type": "focusedwindow",
          "id": "focusedwindow-a"
        }
      ],
      "center": [
        {
          "type": "media",
          "id": "media-a"
        },
        {
          "type": "clock",
          "id": "clock-a"
        },
        {
          "type": "weather",
          "id": "weather-a"
        }
      ],
      "right": [
        {
          "type": "systemtray",
          "id": "systemtray-a"
        },
        {
          "type": "clipboard",
          "id": "clipboard-a"
        },
        {
          "type": "cpu",
          "id": "cpu-a"
        },
        {
          "type": "memory",
          "id": "memory-a"
        },
        {
          "type": "notifications",
          "id": "notifications-a"
        },
        {
          "type": "battery",
          "id": "battery-a"
        },
        {
          "type": "controlcenter",
          "id": "controlcenter-a"
        }
      ]
    },
    "bgOpacity": 1.0
  },
  "workspaces": {
    "numbered": true,
    "showNames": false,
    "minCount": 0,
    "showApps": false,
    "followMonitor": false,
    "onlyOccupied": true,
    "invertScroll": false,
    "focusedColor": "primary",
    "occupiedColor": "surface",
    "unfocusedColor": "none",
    "urgentColor": "error",
    "focusedBorder": false
  },
  "notifications": {
    "dnd": false
  },
  "displays": {
    "activeProfile": "",
    "formatByModel": false,
    "snap": true,
    "profiles": []
  },
  "layout": {
    "gapsIn": 4,
    "gapsOut": 10,
    "borderSize": 2,
    "workspaceCount": 10,
    "roundingHypr": 12
  },
  "behavior": {
    "focusFollowsMouse": true,
    "defaultTerminal": "ghostty",
    "defaultBrowser": "auto",
    "fileManager": "vexyon",
    "wallpaper": "vexyon:default",
    "wallpaperDir": "~/Pictures/Wallpapers",
    "screenshotDir": "~/Pictures/Screenshots"
  },
  "keybindMods": {
    "workspaceSwitch": [
      "SUPER"
    ],
    "workspaceMove": [
      "SUPER",
      "SHIFT"
    ]
  },
  "keybinds": [
    {
      "id": "terminal",
      "mods": [
        "SUPER"
      ],
      "key": "T",
      "action": "exec",
      "arg": "ghostty",
      "desc": "Open terminal (Ghostty + Fish)",
      "category": "Apps"
    },
    {
      "id": "killwindow",
      "mods": [
        "SUPER"
      ],
      "key": "Q",
      "action": "dispatch",
      "arg": "killactive",
      "desc": "Kill window under cursor",
      "category": "Window"
    },
    {
      "id": "launcher",
      "mods": [
        "SUPER"
      ],
      "key": "A",
      "action": "global",
      "arg": "launcher",
      "desc": "Open App Launcher",
      "category": "Vexyon"
    },
    {
      "id": "filemanager",
      "mods": [
        "SUPER"
      ],
      "key": "E",
      "action": "global",
      "arg": "filemanager",
      "desc": "Open File Manager",
      "category": "Apps"
    },
    {
      "id": "browser",
      "mods": [
        "SUPER"
      ],
      "key": "B",
      "action": "exec",
      "arg": "vexyon-open-browser",
      "desc": "Open default browser",
      "category": "Apps"
    },
    {
      "id": "controlcenter",
      "mods": [
        "SUPER"
      ],
      "key": "C",
      "action": "global",
      "arg": "controlcenter",
      "desc": "Open Control Center",
      "category": "Vexyon"
    },
    {
      "id": "togglefloat",
      "mods": [
        "SUPER"
      ],
      "key": "W",
      "action": "dispatch",
      "arg": "togglefloating",
      "desc": "Toggle floating for window under cursor",
      "category": "Window"
    },
    {
      "id": "fullscreen",
      "mods": [
        "SUPER",
        "SHIFT"
      ],
      "key": "F",
      "action": "dispatch",
      "arg": "fullscreen 0",
      "desc": "Toggle fullscreen for focused window",
      "category": "Window"
    },
    {
      "id": "wallpaper",
      "mods": [
        "SUPER",
        "ALT"
      ],
      "key": "W",
      "action": "global",
      "arg": "wallpaper",
      "desc": "Open Wallpaper Picker",
      "category": "Vexyon"
    },
    {
      "id": "scratchToggle",
      "mods": [
        "SUPER"
      ],
      "key": "S",
      "action": "dispatch",
      "arg": "togglespecialworkspace scratchpad",
      "desc": "Toggle Scratchpad",
      "category": "Workspace"
    },
    {
      "id": "scratchSend",
      "mods": [
        "SUPER",
        "SHIFT"
      ],
      "key": "S",
      "action": "dispatch",
      "arg": "movetoworkspacesilent special:scratchpad",
      "desc": "Send window under cursor to Scratchpad",
      "category": "Workspace"
    },
    {
      "id": "focusLeft",
      "mods": [
        "SUPER"
      ],
      "key": "left",
      "action": "dispatch",
      "arg": "movefocus l",
      "desc": "Move focus left",
      "category": "Focus"
    },
    {
      "id": "focusRight",
      "mods": [
        "SUPER"
      ],
      "key": "right",
      "action": "dispatch",
      "arg": "movefocus r",
      "desc": "Move focus right",
      "category": "Focus"
    },
    {
      "id": "focusUp",
      "mods": [
        "SUPER"
      ],
      "key": "up",
      "action": "dispatch",
      "arg": "movefocus u",
      "desc": "Move focus up",
      "category": "Focus"
    },
    {
      "id": "focusDown",
      "mods": [
        "SUPER"
      ],
      "key": "down",
      "action": "dispatch",
      "arg": "movefocus d",
      "desc": "Move focus down",
      "category": "Focus"
    },
    {
      "id": "swapLeft",
      "mods": [
        "SUPER",
        "SHIFT"
      ],
      "key": "left",
      "action": "dispatch",
      "arg": "swapwindow l",
      "desc": "Swap window left",
      "category": "Focus"
    },
    {
      "id": "swapRight",
      "mods": [
        "SUPER",
        "SHIFT"
      ],
      "key": "right",
      "action": "dispatch",
      "arg": "swapwindow r",
      "desc": "Swap window right",
      "category": "Focus"
    },
    {
      "id": "swapUp",
      "mods": [
        "SUPER",
        "SHIFT"
      ],
      "key": "up",
      "action": "dispatch",
      "arg": "swapwindow u",
      "desc": "Swap window up",
      "category": "Focus"
    },
    {
      "id": "swapDown",
      "mods": [
        "SUPER",
        "SHIFT"
      ],
      "key": "down",
      "action": "dispatch",
      "arg": "swapwindow d",
      "desc": "Swap window down",
      "category": "Focus"
    },
    {
      "id": "screenshot",
      "mods": [],
      "key": "Print",
      "action": "global",
      "arg": "screenshot",
      "desc": "Interactive screenshot / snip",
      "category": "Vexyon"
    },
    {
      "id": "lock",
      "mods": [
        "SUPER"
      ],
      "key": "L",
      "action": "global",
      "arg": "lock",
      "desc": "Lock screen",
      "category": "Session"
    },
    {
      "id": "powermenu",
      "mods": [
        "SUPER"
      ],
      "key": "X",
      "action": "global",
      "arg": "powermenu",
      "desc": "Power menu",
      "category": "Session"
    },
    {
      "id": "themeswitcher",
      "mods": [
        "SUPER",
        "ALT"
      ],
      "key": "T",
      "action": "global",
      "arg": "themeswitcher",
      "desc": "Switch theme (quick)",
      "category": "Vexyon"
    },
    {
      "id": "volumeUp",
      "mods": [],
      "key": "XF86AudioRaiseVolume",
      "action": "global",
      "arg": "volumeUp",
      "flags": "el",
      "desc": "Volume up",
      "category": "Media"
    },
    {
      "id": "volumeDown",
      "mods": [],
      "key": "XF86AudioLowerVolume",
      "action": "global",
      "arg": "volumeDown",
      "flags": "el",
      "desc": "Volume down",
      "category": "Media"
    },
    {
      "id": "volumeMute",
      "mods": [],
      "key": "XF86AudioMute",
      "action": "global",
      "arg": "volumeMute",
      "flags": "l",
      "desc": "Toggle mute",
      "category": "Media"
    },
    {
      "id": "micMute",
      "mods": [],
      "key": "XF86AudioMicMute",
      "action": "global",
      "arg": "micMute",
      "flags": "l",
      "desc": "Toggle microphone mute",
      "category": "Media"
    },
    {
      "id": "brightnessUp",
      "mods": [],
      "key": "XF86MonBrightnessUp",
      "action": "global",
      "arg": "brightnessUp",
      "flags": "el",
      "desc": "Brightness up",
      "category": "Media"
    },
    {
      "id": "brightnessDown",
      "mods": [],
      "key": "XF86MonBrightnessDown",
      "action": "global",
      "arg": "brightnessDown",
      "flags": "el",
      "desc": "Brightness down",
      "category": "Media"
    },
    {
      "id": "mediaPlayPause",
      "mods": [],
      "key": "XF86AudioPlay",
      "action": "global",
      "arg": "mediaPlayPause",
      "flags": "l",
      "desc": "Play / pause media",
      "category": "Media"
    },
    {
      "id": "mediaPause",
      "mods": [],
      "key": "XF86AudioPause",
      "action": "global",
      "arg": "mediaPause",
      "flags": "l",
      "desc": "Pause media",
      "category": "Media"
    },
    {
      "id": "mediaNext",
      "mods": [],
      "key": "XF86AudioNext",
      "action": "global",
      "arg": "mediaNext",
      "flags": "l",
      "desc": "Next track",
      "category": "Media"
    },
    {
      "id": "mediaPrev",
      "mods": [],
      "key": "XF86AudioPrev",
      "action": "global",
      "arg": "mediaPrev",
      "flags": "l",
      "desc": "Previous track",
      "category": "Media"
    }
  ],
  "mouseBinds": [
    {
      "id": "moveFloat",
      "mods": [
        "SUPER"
      ],
      "button": "mouse:272",
      "action": "movewindow",
      "desc": "Move floating window (hold Super + Left click)"
    },
    {
      "id": "resizeFloat",
      "mods": [
        "SUPER"
      ],
      "button": "mouse:273",
      "action": "resizewindow",
      "desc": "Resize floating window (hold Super + Right click)"
    }
  ]
}
