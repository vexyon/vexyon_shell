[Desktop Entry]
# Vexyon session entry (installed to /usr/share/wayland-sessions/vexyon.desktop).
# The Vexyon greeter scans this dir and prefers this entry; Exec goes through
# vexyon-start (session env hints + the start-hyprland watchdog wrapper) so
# Hyprland is never launched as a bare binary.
Name=Vexyon
Comment=Vexyon shell on Hyprland
Exec=/usr/local/bin/vexyon-start
Type=Application
DesktopNames=Hyprland
Keywords=vexyon;hyprland;wayland;
