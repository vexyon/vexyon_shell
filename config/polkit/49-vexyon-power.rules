// Vexyon — permite a los usuarios del grupo `wheel` suspender / reiniciar /
// apagar / hibernar sin contraseña (los botones del power menu del shell).
//
// Por qué por grupo y no por "sesión activa": el shell lanza el comando
// (systemctl/loginctl) de forma desatendida (Quickshell.execDetached hace
// setsid), así que el proceso ya NO pertenece a la sesión gráfica activa y
// una regla `subject.active` NO coincide → polkit responde "challenge" y el
// comando desatendido no puede lanzar el diálogo → "interactive
// authentication required" y la acción falla en silencio.
//
// Conceder las acciones de login1 al grupo `wheel` (el usuario del escritorio,
// que ya tiene sudo) hace que funcionen siempre. Ámbito acotado a las 8
// acciones de energía; una sesión SSH del mismo usuario también podría
// invocarlas, trade-off aceptable en una estación de un solo usuario (ya
// tiene sudo). Se instala en /etc/polkit-1/rules.d/ (install.sh).
polkit.addRule(function(action, subject) {
    if (action.id.indexOf("org.freedesktop.login1.") !== 0) return;
    if (!subject.isInGroup("wheel")) return;
    switch (action.id) {
    case "org.freedesktop.login1.power-off":
    case "org.freedesktop.login1.power-off-multiple-sessions":
    case "org.freedesktop.login1.reboot":
    case "org.freedesktop.login1.reboot-multiple-sessions":
    case "org.freedesktop.login1.suspend":
    case "org.freedesktop.login1.suspend-multiple-sessions":
    case "org.freedesktop.login1.hibernate":
    case "org.freedesktop.login1.hibernate-multiple-sessions":
        return polkit.Result.YES;
    }
});
